# Qdrant配置
QDRANT_HOST=localhost
QDRANT_PORT=6333
QDRANT_COLLECTION=crm_filters

# Docker 构建基础镜像
PYTHON_BASE_IMAGE=python:3.10-slim
APP_IMAGE_NAME=rag-crm-agent:local

# Ollama配置
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=deepseek-r1:7b
OLLAMA_TIMEOUT_SEC=300
OLLAMA_NUM_PREDICT=96

# Docker 缓存目录映射（Windows 路径建议使用正斜杠）
DOCKER_OLLAMA_HOME=C:/Users/Lenovo/.ollama
DOCKER_ST_CACHE_DIR=C:/Users/Lenovo/.cache/torch/sentence_transformers

# 嵌入模型
EMBEDDING_MODEL=BAAI/bge-large-zh-v1.5
EMBEDDING_DEVICE=cpu
RETRIEVAL_VECTOR_BACKEND=auto
RETRIEVAL_BM25_WEIGHT=0.55
RETRIEVAL_VECTOR_WEIGHT=0.45
RETRIEVAL_RERANK_BLEND=0.35
RETRIEVAL_CANDIDATE_MULTIPLIER=4
MODEL_SPEC_REPAIR_MAX_ROUNDS=2

# 会话缓存配置
SESSION_STORE_BACKEND=memory
SESSION_HISTORY_SIZE=50
CHAT_HISTORY_WINDOW=12
FALLBACK_HISTORY_WINDOW=6
PLANNER_HISTORY_WINDOW=4
SESSION_TTL_SEC=604800

# Redis配置
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=
REDIS_KEY_PREFIX=rag_crm_agent:session

# API配置
API_HOST=0.0.0.0
API_PORT=8000
LOCAL_BUILD_MCP_DRY_RUN=0
